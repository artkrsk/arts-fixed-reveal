{
  "name": "arts/fixed-reveal",
  "type": "library",
  "description": "Scroll-driven fixed reveal effect for Elementor",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Artem Semkin",
      "email": "me@artemsemkin.com"
    }
  ],
  "require": {
    "php": ">=8.0",
    "arts/elementor-extension": "@dev",
    "arts/gsap-loader": "@dev",
    "arts/utilities": "@dev"
  },
  "repositories": [
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsElementorExtension",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsGSAPLoader",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsUtilities",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "autoload": {
    "psr-4": {
      "Arts\\FixedReveal\\": "src/php/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
